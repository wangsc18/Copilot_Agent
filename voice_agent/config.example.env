# Voice feature switch
VOICE_ENABLED=false
VOICE_MODE=hybrid
VOICE_FALLBACK_TEXT=true
VOICE_PROVIDERS=volcengine,mock
VOICE_ENABLE_PROVIDER_PROBE=false

# OpenAI realtime
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_URL=wss://api.openai.com/v1/realtime
OPENAI_REALTIME_VOICE=alloy

# Audio and turn parameters
VOICE_SAMPLE_RATE_HZ=16000
VOICE_FRAME_MS=20
VOICE_VAD_SILENCE_MS=450

# Local STT (phase-1: mic -> text)
LOCAL_STT_ENABLED=false
LOCAL_STT_MODEL=base
LOCAL_STT_DEVICE=auto
LOCAL_STT_COMPUTE_TYPE=auto

# Volcengine realtime
VOLCENGINE_REALTIME_URL=wss://openspeech.bytedance.com/api/v3/realtime/dialogue
VOLCENGINE_APP_ID=
VOLCENGINE_ACCESS_KEY=
VOLCENGINE_RESOURCE_ID=volc.speech.dialog
VOLCENGINE_APP_KEY=PlgvMymc7f3tQnJ6
VOLCENGINE_MODEL=o2.0
